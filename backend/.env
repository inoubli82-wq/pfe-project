# ===========================================
# DATABASE CONFIGURATION - PostgreSQL
# ===========================================

# Connection String (change password to your PostgreSQL password)
DATABASE_URL=postgresql://postgres:password:@localhost:5432/pfe_import_export

# Individual Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pfe_import_export
DB_USER=postgres
DB_PASSWORD=123

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# URLs Frontend (pour CORS)
FRONTEND_URL=http://localhost
FLUTTER_EMULATOR_URL=http://10.0.2.2

# ===========================================
# JWT SECRET (for token generation)
# ===========================================
JWT_SECRET=pfe_import_export_secret_key_2024